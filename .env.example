# Copy this file to ".env" and fill in your real values.
# .env is gitignored; real environment variables override anything set here.

# Shared password required for write endpoints (serve mode).
BOOKWATCH_PASSWORD=

# Absolute path to your vault root.
BOOKWATCH_VAULT_DIR=./vault

# Folder scanned for #LightNovel notes (defaults to <vault>/LightNovel).
# BOOKWATCH_SCAN_ROOT=

# New-note + attachments folders — each can be relative to the vault or a
# full path.
# BOOKWATCH_NEW_NOTE_DIR=LightNovel
# BOOKWATCH_ATTACHMENTS_DIR=LightNovel/_attachments

# #Book equivalents of the three settings above. Blank falls back to the
# matching LN setting, so a single-folder setup keeps working unchanged.
# BOOKWATCH_BOOK_SCAN_ROOT=
# BOOKWATCH_BOOK_NEW_NOTE_DIR=
# BOOKWATCH_BOOK_ATTACHMENTS_DIR=

# HTTP listen port.
# BOOKWATCH_PORT=8080

# Cron expression for the scheduled check.
# BOOKWATCH_CHECK_CRON=0 9 * * *
