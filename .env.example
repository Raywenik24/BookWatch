# Copy this file to ".env" and fill in your real values.
# .env is gitignored; real environment variables override anything set here.

# Shared password required for write endpoints (serve mode).
BOOKWATCH_PASSWORD=

# Absolute path to your vault root.
BOOKWATCH_VAULT_DIR=./vault

# Folder scanned for #LightNovel notes (defaults to <vault>/LightNovel).
# BOOKWATCH_SCAN_ROOT=

# New-note + attachments folders, relative to the vault.
# BOOKWATCH_NEW_NOTE_DIR=LightNovel
# BOOKWATCH_ATTACHMENTS_DIR=LightNovel/_attachments

# HTTP listen port.
# BOOKWATCH_PORT=8080

# Cron expression for the scheduled check.
# BOOKWATCH_CHECK_CRON=0 9 * * *
